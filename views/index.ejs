<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Plataforma de Cursos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">Plataforma de Cursos</a>
        <div class="d-flex">
            <a href="/login" class="btn btn-outline-light">Login</a>
        </div>
    </div>
</nav>

<div class="container mt-5">

    <div id="mensagem"></div>

    <h3>Cadastrar Curso</h3>

    <input id="titulo" class="form-control mb-2" placeholder="Título">
    <input id="descricao" class="form-control mb-2" placeholder="Descrição">
    <input id="preco" class="form-control mb-2" placeholder="Preço">
    <input id="carga" type="number" class="form-control mb-2" placeholder="Carga horária (horas)">

    <button class="btn btn-primary mb-4" onclick="cadastrarCurso()">Cadastrar</button>

    <hr>

    <h3>Lista de Cursos</h3>
    <div class="row" id="listaCursos"></div>

</div>

<script src="/script.js"></script>
</body>
</html>